int inversonum (int n)
{
    int numeroinvertido = 0;
    while(n >0)
    {
        int cifra = n % 10;
        numeroinvertido = numeroinvertido * 10 + cifra;
        n = n / 10;
    }
    return numeroinvertido;
}

